{
  "name": "race-results-api",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "esbuild index.ts --bundle --external:@aws-sdk --sourcemap --platform=node --target=es2020 --metafile=dist/metadata.json --outfile=dist/index.js",
    "postbuild": "cd dist && zip -r index.zip index.js*",
    "test": "node --experimental-strip-types test.ts",
    "dev": "nodemon --exec 'node --experimental-strip-types' dev-server.ts",
    "deploy": "aws lambda update-function-code --function-name race-results-api-stage --output json --no-cli-pager --zip-file fileb://dist/index.zip && aws lambda update-function-code --function-name race-results-api-prod --output json --no-cli-pager --zip-file fileb://dist/index.zip",
    "push": "npm run build && npm run deploy"
  },
  "author": "Alex Clement",
  "license": "ISC",
  "description": "",
  "type": "module",
  "devDependencies": {
    "@types/aws-lambda": "^8.10.152",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.3.0",
    "esbuild": "^0.25.9",
    "nodemon": "^3.1.0"
  },
  "peerDependencies": {
    "aws-lambda": "1.0.7"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.873.0",
    "@aws-sdk/util-dynamodb": "^3.873.0",
    "@fastify/aws-lambda": "^6.4.0",
    "@fastify/cors": "^11.2.0",
    "deep-object-diff": "^1.1.9",
    "fastify": "^5.7.4",
    "fastify-plugin": "^5.1.0",
    "jsonwebtoken": "^9.0.3"
  }
}
