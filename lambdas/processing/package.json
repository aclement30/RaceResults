{
  "name": "race-results-processing",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "esbuild index.ts --bundle --external:@aws-sdk --sourcemap --platform=node --target=es2020 --metafile=dist/metadata.json --outfile=dist/index.js",
    "postbuild": "cd dist && zip -r index.zip index.js*",
    "local": "node --experimental-strip-types run-local.ts",
    "test": "cd .. && npm test",
    "test:watch": "cd .. && npm run test:watch",
    "test:coverage": "cd .. && npm run test:coverage",
    "deploy": "aws lambda update-function-code --function-name race-results-processing-prod --output json --no-cli-pager --zip-file fileb://dist/index.zip"
  },
  "author": "Alex Clement",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.15.26",
    "esbuild": "^0.25.5"
  },
  "dependencies": {
    "colors": "^1.4.0",
    "deep-object-diff": "^1.1.9",
    "jest-diff": "^30.2.0",
    "lodash-es": "^4.17.23"
  }
}
